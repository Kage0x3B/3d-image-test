{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "3d-image",
    "main": ".svelte-kit/cloudflare/_worker.js",
    "compatibility_date": "2026-01-20",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "observability": {
        "enabled": true
    },
    "assets": {
        "binding": "ASSETS",
        "directory": ".svelte-kit/cloudflare"
    },
    "route": {
        "pattern": "3d-image.moritz.website",
        "custom_domain": true
    }
}
